# TronSage AI Agent - Environment Variables
# Copy this to .env.local and fill in your values

# ───────────────────────────────────────────
# Kimi (Moonshot AI) — 核心 AI 能力（对话 + 分析）
# 获取地址：https://platform.moonshot.cn/console/api-keys
# ───────────────────────────────────────────
KIMI_API_KEY=sk-your-kimi-key-here

# ───────────────────────────────────────────
# TRON Configuration
# ───────────────────────────────────────────
# TronGrid API key (optional, increases rate limits)
# Get from: https://www.trongrid.io/
TRONGRID_API_KEY=

# TronScan API key (optional)
# Get from: https://tronscan.org/
TRONSCAN_API_KEY=

# ───────────────────────────────────────────
# Bank of AI - x402 Payment Protocol
# Your TRON wallet to receive AI payments
# ───────────────────────────────────────────
# Address of the AI agent's TRON wallet (receives 0.1 USDT/USDD per query)
AGENT_TRON_ADDRESS=TYourTronWalletAddressHere

# Private key of the AI agent's wallet (for server-side TRC20 transfers + on-chain memo anchoring)
# Required for: multi-agent real payments, prediction on-chain anchoring
# ⚠️  NEVER commit this to git — keep only in .env.local
AGENT_TRON_PRIVATE_KEY=your-64-char-hex-private-key-here

# ───────────────────────────────────────────
# Bank of AI - 8004 Identity Protocol
# (No API key required — identity is computed locally + verified via TronScan)
# ───────────────────────────────────────────
BANKOFAI_AGENT_ID=tronsage-agent-001

# ───────────────────────────────────────────
# Telegram Bot Integration
# ───────────────────────────────────────────
# 从 @BotFather 获取 Bot Token
# 1. 在 Telegram 中搜索 @BotFather
# 2. 发送 /newbot，按提示创建机器人
# 3. 复制下发的 Token 填入此处
TELEGRAM_BOT_TOKEN=

# Webhook 验证密钥（自行设置32+位随机字符串，增强安全性）
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string

# Webhook 注册命令（部署后执行）：
# curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://your-domain.com/api/bot/telegram&secret_token=<SECRET>"

# ───────────────────────────────────────────
# 飞书 Bot Integration
# ───────────────────────────────────────────
# 在飞书开放平台 (open.feishu.cn) 创建企业自建应用
# 需开启「机器人」能力，并申请权限：im:message、im:message:send_as_bot
# 事件订阅中添加：im.message.receive_v1
# 请求网址设为：https://your-domain.com/api/bot/feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 飞书开放平台「事件订阅」页面的 Verification Token
FEISHU_VERIFICATION_TOKEN=

# ───────────────────────────────────────────
# App Configuration
# ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# x402 payment amount (in USDT, 6 decimals)
NEXT_PUBLIC_ANALYSIS_PRICE_USDT=0.1
# USDT contract on TRON mainnet
NEXT_PUBLIC_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# USDD contract on TRON mainnet  
NEXT_PUBLIC_USDD_CONTRACT=TPYmHEhy5n8TCEfYGqW2rPxsghSfzghPDn
