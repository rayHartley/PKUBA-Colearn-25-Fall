PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Optional API key for higher TRON request limits.
TRONGRID_API_KEY=
REQUEST_TIMEOUT_MS=12000
OVERVIEW_CACHE_TTL_MS=180000
HOT_WALLETS_CACHE_TTL_MS=180000

# Optional OpenAI-compatible LLM settings. If omitted, the app falls back to
# deterministic, template-based insights.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# x402 paywall settings
X402_MODE=demo
X402_NETWORK=tron-nile
X402_ASSET=USDT
X402_ASSET_ADDRESS=
X402_ASSET_DECIMALS=6
X402_PAY_TO=
X402_PRICE_ATOMIC=1000000
X402_DEMO_TOKEN=demo-paid
X402_REALM=TRON Whale Radar Premium
# For real Bank of AI integration, switch X402_MODE=facilitator and use:
# X402_FACILITATOR_URL=https://facilitator.bankofai.io
# X402_FACILITATOR_API_KEY=your_bankofai_api_key
X402_FACILITATOR_URL=
X402_FACILITATOR_API_KEY=

# Optional custom watchlist (format: label|address,label|address)
DEFAULT_WATCHLIST=
