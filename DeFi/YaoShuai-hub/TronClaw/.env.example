# ======================
# TRON Network
# ======================
# nile (testnet) | mainnet
TRON_NETWORK=nile
# Your TRON wallet private key (testnet only, NEVER use mainnet key here)
TRON_PRIVATE_KEY=
# TronGrid API key (get from https://www.trongrid.io/)
TRONGRID_API_KEY=

# ======================
# Bank of AI (x402)
# ======================
# Address to receive payments via x402 protocol
X402_PAYMENT_ADDRESS=
# Bank of AI platform API key
BANK_OF_AI_API_KEY=

# ======================
# Server
# ======================
PORT=3000
# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ======================
# Database
# ======================
DATABASE_PATH=./data.db

# ======================
# LLM (for built-in Agent in Chat UI)
# ======================
# anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ======================
# Mock Mode (set to true when testnet is unstable)
# ======================
MOCK_TRON=false

# ======================
# Proxy (for Gemini API in restricted regions)
# ======================
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
